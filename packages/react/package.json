{
  "name": "@anvia/react",
  "version": "0.7.2",
  "description": "React hooks and client transports for Anvia applications.",
  "author": "anvia",
  "maintainer": "Indra Zulfi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anvia-hq/anvia",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --external react",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@anvia/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "happy-dom": "20.9.0",
    "react": "^19.2.6",
    "react-dom": "19.2.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
