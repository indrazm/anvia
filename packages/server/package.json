{
  "name": "@anvia/server",
  "version": "0.4.8",
  "description": "Server-side event stream helpers for Anvia applications.",
  "author": "anvia",
  "maintainer": "Indra Zulfi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anvia-hq/anvia",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anvia/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "4.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
