<div class="hidden min-w-0 flex-1 max-w-xl md:block" data-docs-search-root>
  <button
    type="button"
    class="flex h-10 w-full min-w-0 items-center gap-3 rounded-lg border border-white/12 bg-white/[0.045] px-3 text-left text-sm text-zinc-400 shadow-sm transition hover:border-white/20 hover:bg-white/[0.06]"
    data-docs-search-open
  >
    <span class="font-mono text-zinc-500">/</span>
    <span class="min-w-0 flex-1 truncate">Search docs...</span>
    <kbd class="rounded-md border border-white/10 bg-[#101011] px-2 py-1 font-mono text-[0.68rem] text-zinc-400">
      Cmd K
    </kbd>
  </button>

  <div
    class="fixed inset-0 z-50 hidden bg-black/55 px-4 py-16 backdrop-blur-sm"
    data-docs-search-dialog
    aria-hidden="true"
  >
    <div class="mx-auto max-w-2xl overflow-hidden rounded-2xl border border-white/[0.1] bg-[#131314] shadow-[0_32px_120px_rgba(0,0,0,0.55)]">
      <div class="flex items-center gap-3 border-white/[0.08] border-b px-4 py-3">
        <span class="font-mono text-[#2BF563]/70">/</span>
        <input
          type="search"
          placeholder="Search documentation..."
          class="min-w-0 flex-1 bg-transparent text-base text-zinc-100 placeholder:text-zinc-400 focus:outline-none"
          data-docs-search-input
        />
        <button
          type="button"
          class="rounded-md px-2 py-1 font-mono text-xs text-zinc-400 transition hover:bg-white/[0.06] hover:text-zinc-100"
          data-docs-search-close
        >
          Esc
        </button>
      </div>

      <div class="max-h-[min(34rem,calc(100dvh-12rem))] overflow-y-auto p-2" data-docs-search-results>
        <p class="px-3 py-8 text-center text-sm text-zinc-400">
          Start typing to search Anvia documentation.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  const root = document.querySelector("[data-docs-search-root]");
  const openButton = root?.querySelector("[data-docs-search-open]");
  const dialog = root?.querySelector("[data-docs-search-dialog]");
  const closeButton = root?.querySelector("[data-docs-search-close]");
  const input = root?.querySelector("[data-docs-search-input]");
  const resultsContainer = root?.querySelector("[data-docs-search-results]");

  let pagefindPromise;

  const sectionLabels = {
    basics: "Basics",
    advanced: "Advanced",
    providers: "Providers",
    examples: "Examples",
    packages: "Packages",
  };

  function openDialog() {
    if (!(dialog instanceof HTMLElement) || !(input instanceof HTMLInputElement)) {
      return;
    }

    dialog.classList.remove("hidden");
    dialog.setAttribute("aria-hidden", "false");
    input.focus();
    loadPagefind();
  }

  function closeDialog() {
    if (!(dialog instanceof HTMLElement)) {
      return;
    }

    dialog.classList.add("hidden");
    dialog.setAttribute("aria-hidden", "true");
  }

  function loadPagefind() {
    const pagefindPath = ["/pagefind", "pagefind.js"].join("/");

    pagefindPromise ??= import(/* @vite-ignore */ pagefindPath)
      .then(async (pagefind) => {
        await pagefind.init();
        return pagefind;
      })
      .catch(() => null);

    return pagefindPromise;
  }

  function escapeHtml(value) {
    return value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");
  }

  function renderMessage(message) {
    if (!(resultsContainer instanceof HTMLElement)) {
      return;
    }

    resultsContainer.innerHTML = `<p class="px-3 py-8 text-center text-sm text-zinc-400">${message}</p>`;
  }

  async function runSearch(query) {
    if (!(resultsContainer instanceof HTMLElement)) {
      return;
    }

    const cleanQuery = query.trim();

    if (!cleanQuery) {
      renderMessage("Start typing to search Anvia documentation.");
      return;
    }

    const pagefind = await loadPagefind();

    if (!pagefind) {
      renderMessage("Search index is unavailable. Run the production build to generate it.");
      return;
    }

    const search = await pagefind.debouncedSearch(cleanQuery);

    if (!search) {
      return;
    }

    const results = await Promise.all(search.results.slice(0, 8).map((result) => result.data()));

    if (results.length === 0) {
      renderMessage("No docs found.");
      return;
    }

    resultsContainer.innerHTML = results
      .map((result) => {
        const title = escapeHtml(result.meta?.title ?? "Untitled doc");
        const section = escapeHtml(sectionLabels[result.meta?.section] ?? result.meta?.section ?? "Docs");
        const excerpt = result.excerpt ?? escapeHtml(result.plain_excerpt ?? "");
        const url = escapeHtml(result.url ?? "#");

        return `
          <a href="${url}" class="block rounded-xl px-3 py-3 transition hover:bg-white/[0.055]">
            <span class="font-mono text-[#2BF563]/70 text-[0.66rem] uppercase tracking-[0.16em]">${section}</span>
            <span class="mt-1 block font-semibold text-zinc-100">${title}</span>
            <span class="mt-1 line-clamp-2 block text-sm leading-6 text-zinc-300">${excerpt}</span>
          </a>
        `;
      })
      .join("");
  }

  openButton?.addEventListener("click", openDialog);
  closeButton?.addEventListener("click", closeDialog);
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) {
      closeDialog();
    }
  });
  input?.addEventListener("input", (event) => {
    const target = event.currentTarget;

    if (target instanceof HTMLInputElement) {
      runSearch(target.value);
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      openDialog();
    }

    if (event.key === "Escape") {
      closeDialog();
    }
  });
</script>
