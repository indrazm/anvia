---
import type { MarkdownHeading } from "astro";
import DocsSearch from "./DocsSearch.astro";
import PostHog from "../posthog.astro";
import {
  docHref,
  docLabel,
  docsSections,
  getSectionLandingHref,
  getSidebarGroups,
  type DocsEntry,
  type DocsSection,
} from "../../lib/docs";
import "../../styles/global.css";

interface Props {
  title: string;
  description: string;
  entries: DocsEntry[];
  activeSection?: DocsSection;
  currentId?: string;
  headings?: MarkdownHeading[];
  customSidebarGroups?: SidebarGroup[];
  sidebarActiveId?: string;
  sidebarScrollKey?: string;
}

interface SidebarEntry {
  id: string;
  href: string;
  label: string;
}

interface SidebarGroup {
  title: string;
  entries: SidebarEntry[];
}

const {
  title,
  description,
  entries,
  activeSection = "basics",
  currentId,
  headings = [],
  customSidebarGroups,
  sidebarActiveId = currentId,
  sidebarScrollKey: sidebarScrollKeyOverride,
} = Astro.props;
const sidebarGroups =
  customSidebarGroups ??
  getSidebarGroups(entries, activeSection).map((group) => ({
    title: group.title,
    entries: group.entries.map((entry) => ({
      id: entry.id,
      href: docHref(entry),
      label: docLabel(entry),
    })),
  }));
const tableOfContents = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const hasTableOfContents = tableOfContents.length > 0;
const githubUrl = "https://github.com/anvia-hq/anvia";
const sidebarScrollKey =
  sidebarScrollKeyOverride ??
  `anvia:docs-sidebar-scroll:${currentId === "packages" ? "packages" : activeSection}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <PostHog />
  </head>
  <body class="flex h-dvh flex-col overflow-hidden bg-[#131314] text-zinc-50 antialiased">
    <header class="sticky top-0 z-40 shrink-0 border-white/10 border-b bg-[#131314]/95 backdrop-blur-xl" data-pagefind-ignore="all">
      <div class="flex h-16 w-full items-center justify-between gap-4 px-4 sm:px-5 lg:px-6">
        <a href="/" aria-label="Anvia home" class="flex shrink-0 items-center gap-2.5">
          <img src="/assets/logo.png" alt="" class="h-[1.375rem] w-auto" />
          <span class="rounded-md bg-[#242426] px-2.5 py-1.5 font-semibold text-xs text-zinc-100 leading-none">
            Docs
          </span>
        </a>

        <DocsSearch />

        <nav class="flex items-center gap-4 font-medium text-sm text-zinc-300" aria-label="Docs utility">
          <a
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Anvia on GitHub"
            class="inline-flex h-9 w-9 items-center justify-center text-zinc-400 transition hover:text-zinc-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.38-3.88-1.38-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.17c.98 0 1.94.13 2.86.39 2.19-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.07.78 2.15v3.03c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
            </svg>
          </a>
          <a href="/" class="transition hover:text-zinc-100">Website -&gt;</a>
        </nav>
      </div>

      <div class="border-white/[0.08] border-t">
        <nav class="flex h-12 w-full gap-7 overflow-x-auto px-4 sm:px-5 lg:px-6" aria-label="Docs sections">
          {
            docsSections.map((section) => (
              <a
                href={getSectionLandingHref(entries, section.id)}
                class:list={[
                  "inline-flex shrink-0 items-center border-b-2 px-0.5 font-semibold text-sm transition",
                  currentId !== "packages" && section.id === activeSection
                    ? "border-[#2BF563] text-zinc-50"
                    : "border-transparent text-zinc-300 hover:text-zinc-100",
                ]}
              >
                {section.label}
              </a>
            ))
          }
          <a
            href="/docs/packages"
            class:list={[
              "inline-flex shrink-0 items-center border-b-2 px-0.5 font-semibold text-sm transition",
              currentId === "packages" || activeSection === "packages"
                ? "border-[#2BF563] text-zinc-50"
                : "border-transparent text-zinc-300 hover:text-zinc-100",
            ]}
          >
            Packages
          </a>
        </nav>
      </div>
    </header>

    <div
      class:list={[
        "grid min-h-0 w-full flex-1 overflow-hidden lg:grid-cols-[18rem_minmax(0,1fr)]",
        hasTableOfContents &&
          "xl:grid-cols-[18rem_minmax(0,1fr)_20rem] 2xl:grid-cols-[18rem_minmax(0,1fr)_22rem]",
      ]}
    >
      <aside
        class="hidden h-full min-h-0 overflow-y-auto border-white/[0.08] border-r px-4 py-7 sm:px-5 lg:block lg:px-6"
        data-pagefind-ignore="all"
        data-docs-sidebar
        data-docs-sidebar-key={sidebarScrollKey}
      >
        <nav class="grid gap-8" aria-label="Docs sidebar">
          {
            sidebarGroups.map((section) => (
              <section>
                <h2 class="font-mono text-[0.68rem] text-zinc-500 uppercase tracking-[0.16em]">
                  {section.title}
                </h2>
                <div class="mt-3 grid">
                  {section.entries.map((entry) => (
                    <a
                      href={entry.href}
                      data-docs-sidebar-active={entry.id === sidebarActiveId ? "true" : undefined}
                      class:list={[
                        "-mx-2.5 flex items-center justify-between rounded-lg px-2.5 py-2 font-medium text-sm transition hover:bg-white/[0.045] hover:text-zinc-100",
                        entry.id === sidebarActiveId ? "bg-white/[0.055] text-zinc-50" : "text-zinc-300",
                      ]}
                    >
                      <span>{entry.label}</span>
                    </a>
                  ))}
                </div>
              </section>
            ))
          }
        </nav>
      </aside>

      <main class="h-full min-h-0 min-w-0 overflow-y-auto px-4 py-14 sm:px-6 sm:py-18 lg:px-10 lg:py-20 xl:px-12 2xl:px-16">
        <slot />
      </main>

      {
        hasTableOfContents && (
          <aside
            class="hidden h-full min-h-0 overflow-y-auto border-white/[0.08] border-l px-6 py-8 xl:block"
            data-pagefind-ignore="all"
          >
            <nav aria-label="On this page">
              <h2 class="font-mono text-[0.68rem] text-zinc-500 uppercase tracking-[0.16em]">
                On this page
              </h2>
              <ol class="mt-4 grid gap-1.5">
                {tableOfContents.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class:list={[
                        "block rounded-md py-1.5 font-medium text-sm leading-5 text-zinc-400 transition hover:bg-white/[0.04] hover:text-zinc-100",
                        heading.depth === 3 ? "px-2.5 pl-5" : "px-2.5",
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )
      }
    </div>

    <script>
      const sidebar = document.querySelector<HTMLElement>("[data-docs-sidebar]");

      if (sidebar) {
        const storageKey = sidebar.dataset.docsSidebarKey;
        const activeLink = sidebar.querySelector<HTMLElement>("[data-docs-sidebar-active]");

        const readStoredScroll = () => {
          if (!storageKey) {
            return undefined;
          }

          try {
            const stored = sessionStorage.getItem(storageKey);
            if (stored === null) {
              return undefined;
            }

            const parsed = Number.parseInt(stored, 10);
            return Number.isFinite(parsed) ? parsed : undefined;
          } catch {
            return undefined;
          }
        };

        const writeStoredScroll = () => {
          if (!storageKey) {
            return;
          }

          try {
            sessionStorage.setItem(storageKey, String(sidebar.scrollTop));
          } catch {
            // Storage may be unavailable in restricted browsing modes.
          }
        };

        const restoreSidebarScroll = () => {
          const storedScroll = readStoredScroll();

          if (storedScroll !== undefined) {
            sidebar.scrollTop = storedScroll;
            return;
          }

          activeLink?.scrollIntoView({ block: "nearest" });
        };

        restoreSidebarScroll();
        requestAnimationFrame(restoreSidebarScroll);

        let pendingFrame = 0;
        sidebar.addEventListener(
          "scroll",
          () => {
            if (pendingFrame !== 0) {
              cancelAnimationFrame(pendingFrame);
            }

            pendingFrame = requestAnimationFrame(() => {
              writeStoredScroll();
              pendingFrame = 0;
            });
          },
          { passive: true },
        );

        sidebar.querySelectorAll("a[href]").forEach((link) => {
          link.addEventListener("click", writeStoredScroll);
        });

        window.addEventListener("pagehide", writeStoredScroll);
      }
    </script>
  </body>
</html>
