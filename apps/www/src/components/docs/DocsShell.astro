---
import DocsSearch from "./DocsSearch.astro";
import {
  docHref,
  docLabel,
  docsSections,
  getSectionLandingHref,
  getSidebarGroups,
  type DocsEntry,
  type DocsSection,
} from "../../lib/docs";
import "../../styles/global.css";

interface Props {
  title: string;
  description: string;
  entries: DocsEntry[];
  activeSection?: DocsSection;
  currentId?: string;
}

const { title, description, entries, activeSection = "runtime", currentId } = Astro.props;
const sidebarGroups = getSidebarGroups(entries, activeSection);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="flex h-dvh flex-col overflow-hidden bg-[#131314] text-zinc-50 antialiased">
    <header class="sticky top-0 z-40 shrink-0 border-white/10 border-b bg-[#131314]/95 backdrop-blur-xl" data-pagefind-ignore="all">
      <div class="flex h-16 w-full items-center justify-between gap-4 px-4 sm:px-5 lg:px-6">
        <a href="/" class="flex shrink-0 items-center gap-2.5 font-semibold text-lg text-zinc-50">
          <img src="/assets/logo.png" alt="" class="h-7 w-7" />
          <span>Anvia Documentation</span>
        </a>

        <DocsSearch />

        <nav class="flex items-center gap-4 font-medium text-sm text-zinc-300" aria-label="Docs utility">
          <a href="/" class="transition hover:text-zinc-100">Website -&gt;</a>
          <a href="/#packages" class="hidden transition hover:text-zinc-100 sm:inline">Get started -&gt;</a>
        </nav>
      </div>

      <div class="border-white/[0.08] border-t">
        <nav class="flex h-12 w-full gap-7 overflow-x-auto px-4 sm:px-5 lg:px-6" aria-label="Docs sections">
          {
            docsSections.map((section) => (
              <a
                href={getSectionLandingHref(entries, section.id)}
                class:list={[
                  "inline-flex shrink-0 items-center border-b-2 px-0.5 font-semibold text-sm transition",
                  section.id === activeSection
                    ? "border-[#E9FF4E] text-zinc-50"
                    : "border-transparent text-zinc-300 hover:text-zinc-100",
                ]}
              >
                {section.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <div class="grid min-h-0 w-full flex-1 overflow-hidden lg:grid-cols-[18rem_1fr]">
      <aside class="hidden h-full min-h-0 overflow-y-auto border-white/[0.08] border-r px-4 py-7 sm:px-5 lg:block lg:px-6" data-pagefind-ignore="all">
        <nav class="grid gap-8" aria-label="Docs sidebar">
          {
            sidebarGroups.map((section) => (
              <section>
                <h2 class="font-mono text-[#E9FF4E]/65 text-[0.68rem] uppercase tracking-[0.16em]">
                  {section.title}
                </h2>
                <div class="mt-3 grid">
                  {section.entries.map((entry) => (
                    <a
                      href={docHref(entry)}
                      class:list={[
                        "-mx-2.5 flex items-center justify-between rounded-lg px-2.5 py-2 font-medium text-sm transition hover:bg-white/[0.045] hover:text-zinc-100",
                        entry.id === currentId ? "bg-white/[0.055] text-zinc-50" : "text-zinc-300",
                      ]}
                    >
                      <span>{docLabel(entry)}</span>
                    </a>
                  ))}
                </div>
              </section>
            ))
          }
        </nav>
      </aside>

      <main class="h-full min-h-0 min-w-0 overflow-y-auto px-4 py-14 sm:px-6 sm:py-18 lg:px-16 lg:py-20">
        <slot />
      </main>
    </div>
  </body>
</html>
