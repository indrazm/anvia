---
interface Props {
  variant: "diagram" | "terminal" | "retrieval" | "tracing";
}

const { variant } = Astro.props;
---

<div class="docs-preview min-h-60 min-w-0 rounded-2xl border border-white/[0.08] bg-[#101011] p-5 shadow-[0_24px_80px_rgba(0,0,0,0.22)]">
  {
    variant === "diagram" && (
      <div class="flex h-full min-h-48 items-center justify-center">
        <img
          src="/assets/illustrations/agent-gateway-minimal.png"
          alt="Agent runtime package flow"
          width="1808"
          height="870"
          loading="lazy"
          decoding="async"
          class="w-full max-w-lg object-contain opacity-95"
        />
      </div>
    )
  }

  {
    variant === "terminal" && (
      <div class="overflow-hidden rounded-xl border border-white/[0.08] bg-[#131314]">
        <div class="flex h-10 items-center justify-between border-white/[0.08] border-b px-4">
          <span class="font-mono text-xs text-zinc-400">terminal</span>
          <span class="font-mono text-xs text-[#E9FF4E]/70">anvia</span>
        </div>
        <pre class="max-w-full overflow-x-auto p-5 font-mono text-sm text-zinc-300 leading-7"><code>$ pnpm add @anvia/core @anvia/openai

$ anvia dev

ready on http://localhost:3000</code></pre>
      </div>
    )
  }

  {
    variant === "retrieval" && (
      <div class="grid h-full min-h-48 content-center gap-4">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
          <span class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-3 py-2 font-mono text-xs text-zinc-400">
            embeddings
          </span>
          <span class="font-mono text-[#E9FF4E]/65">-&gt;</span>
          <span class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-3 py-2 font-mono text-xs text-zinc-400">
            vector store
          </span>
        </div>
        <div class="rounded-xl border border-[#E9FF4E]/20 bg-[#E9FF4E]/8 px-4 py-3 font-mono text-sm text-[#E9FF4E]">
          retrieve(query, topK: 8)
        </div>
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
          <span class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-3 py-2 font-mono text-xs text-zinc-400">
            context
          </span>
          <span class="font-mono text-[#E9FF4E]/65">-&gt;</span>
          <span class="rounded-lg border border-white/[0.08] bg-white/[0.04] px-3 py-2 font-mono text-xs text-zinc-400">
            agent
          </span>
        </div>
      </div>
    )
  }

  {
    variant === "tracing" && (
      <div class="grid h-full min-h-48 content-center gap-3">
        {["session.created", "model.completed", "tool.called", "trace.exported"].map((event) => (
          <div class="grid grid-cols-[7.5rem_1fr] gap-3 rounded-xl border border-white/[0.08] bg-white/[0.035] px-4 py-3">
            <span class="font-mono text-xs text-[#E9FF4E]/65">event</span>
            <span class="font-mono text-sm text-zinc-300">{event}</span>
          </div>
        ))}
      </div>
    )
  }
</div>

<style>
  .docs-preview {
    background-image:
      linear-gradient(135deg, rgba(233, 255, 78, 0.035) 0 1px, transparent 1px 28px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0));
  }
</style>
