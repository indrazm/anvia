---
import Button from "./ui/Button.astro";

const githubUrl = "https://github.com/anvia-hq/anvia";

const menuGroups = [
  {
    label: "Docs",
    href: "/docs",
    items: [],
  },
  {
    label: "Resources",
    items: [
      { label: "Packages", href: "/docs/packages" },
      { label: "Changelog", href: "/docs/packages/core/changelog" },
      { label: "Providers", href: "/docs/providers/overview" },
    ],
  },
  {
    label: "For Agents",
    items: [
      { label: "llms.txt", href: "/llms.txt" },
      { label: "llms-full.txt", href: "/llms-full.txt" },
    ],
  },
  {
    label: "Sponsors",
    href: "/sponsors",
    items: [],
  },
];
---

<header class="sticky top-0 z-30 border-white/10 border-b bg-[#131314]/90 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex shrink-0 items-center" aria-label="Anvia home">
      <img src="/assets/logo.png" alt="Anvia" class="h-[1.375rem] w-auto" />
    </a>

    <nav class="hidden items-center gap-7 font-medium text-sm lg:flex" aria-label="Primary">
      {
        menuGroups.map((group) => (
          <div class="group relative">
            {
              group.href ? (
                <a
                  href={group.href}
                  class="inline-flex h-10 items-center gap-2 text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
                >
                  {group.label}
                </a>
              ) : (
                <button
                  type="button"
                  class="inline-flex h-10 items-center gap-2 text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
                  aria-haspopup={group.items.length > 0 ? "true" : undefined}
                >
                  <span>{group.label}</span>
                  {group.items.length > 0 && (
                    <span
                      aria-hidden="true"
                      class="mt-[-5px] h-2 w-2 rotate-45 border-zinc-500 border-r border-b transition group-hover:border-zinc-100"
                    />
                  )}
                </button>
              )
            }

            {group.items.length > 0 && (
              <div class="pointer-events-none absolute left-0 top-full hidden w-80 pt-3 opacity-0 transition group-hover:block group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:block group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="border border-white/[0.12] bg-[#080809]/98 p-4 shadow-[0_28px_90px_rgba(0,0,0,0.44)]">
                  <div class="grid gap-1">
                    {group.items.map((item) => (
                      <a
                        href={item.href}
                        class="px-3 py-2.5 text-left font-medium text-sm text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2.5 sm:flex">
      <a
        href={githubUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="Anvia on GitHub"
        class="inline-flex h-9 w-9 items-center justify-center text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.38-3.88-1.38-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.17c.98 0 1.94.13 2.86.39 2.19-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.07.78 2.15v3.03c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
      </a>
      <Button variant="outline" size="xs" href="/docs">Read docs</Button>
    </div>

    <details class="group relative lg:hidden">
      <summary class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-lg border border-white/15 bg-white/[0.055] text-zinc-100 transition hover:bg-white/[0.085]">
        <span class="sr-only">Open menu</span>
        <span aria-hidden="true" class="flex flex-col gap-1.5">
          <span class="block h-px w-4 bg-current"></span>
          <span class="block h-px w-4 bg-current"></span>
          <span class="block h-px w-4 bg-current"></span>
        </span>
      </summary>

      <div class="absolute right-0 top-12 w-[min(20rem,calc(100vw-2rem))] rounded-2xl border border-white/[0.1] bg-[#181819] p-3 shadow-[0_24px_80px_rgba(0,0,0,0.42)]">
        <div class="grid gap-2">
          {
            menuGroups.map((group) => (
              <section class="rounded-xl bg-white/[0.035] p-3">
                <p class="font-mono text-[#2BF563]/65 text-[0.64rem] uppercase tracking-[0.16em]">
                  {group.label}
                </p>
                {group.items.length > 0 && (
                  <div class="mt-2 grid gap-1">
                    {group.items.map((item) => (
                      <a href={item.href} class="text-left text-sm text-zinc-300">
                        {item.label}
                      </a>
                    ))}
                  </div>
                )}
                {group.href && (
                  <a href={group.href} class="mt-2 inline-flex text-left text-sm text-zinc-300">
                    Open {group.label.toLowerCase()}
                  </a>
                )}
              </section>
            ))
          }
        </div>
        <div class="mt-3 grid gap-2">
          <a
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
            aria-label="Anvia on GitHub"
            class="mx-auto inline-flex h-10 w-10 items-center justify-center text-zinc-300 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#2BF563]"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-current">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.88-1.38-3.88-1.38-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.17c.98 0 1.94.13 2.86.39 2.19-1.49 3.16-1.18 3.16-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.07.78 2.15v3.03c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
            </svg>
          </a>
          <Button variant="outline" size="md" href="/docs">Read docs</Button>
        </div>
      </div>
    </details>
  </div>
</header>
