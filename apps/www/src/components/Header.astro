---
const menuGroups = [
  {
    label: "Docs",
    items: [],
  },
  {
    label: "Resources",
    items: ["Best Practices", "Frameworks", "Changelog", "Studio", "Reference", "Models"],
  },
  {
    label: "For agents",
    items: ["Agent Runtime", "Model Providers", "Retrieval", "Tools", "Tracing", "UI Transports"],
  },
  {
    label: "Sponsors",
    items: [],
  },
];
---

<header class="sticky top-0 z-30 border-white/10 border-b bg-[#131314]/90 backdrop-blur-xl">
  <div class="mx-auto flex h-[4.5rem] max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <div class="flex shrink-0 items-center gap-2.5 font-semibold text-xl text-zinc-50">
      <img src="/assets/logo.png" alt="" class="h-7 w-7" />
      <span>Anvia</span>
    </div>

    <nav class="hidden items-center gap-7 font-medium text-sm lg:flex" aria-label="Primary">
      {
        menuGroups.map((group) => (
          <div class="group relative">
            <button
              type="button"
              class="inline-flex h-10 items-center gap-2 text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#E9FF4E]"
              aria-haspopup={group.items.length > 0 ? "true" : undefined}
            >
              <span>{group.label}</span>
              {group.items.length > 0 && (
                <span
                  aria-hidden="true"
                  class="mt-[-5px] h-2 w-2 rotate-45 border-zinc-500 border-r border-b transition group-hover:border-zinc-100"
                />
              )}
            </button>

            {group.items.length > 0 && (
              <div class="pointer-events-none absolute left-0 top-full hidden w-80 pt-3 opacity-0 transition group-hover:block group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:block group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="border border-white/[0.12] bg-[#080809]/98 p-4 shadow-[0_28px_90px_rgba(0,0,0,0.44)]">
                  <div class="grid gap-1">
                    {group.items.map((item) => (
                      <button
                        type="button"
                        class="px-3 py-2.5 text-left font-medium text-sm text-zinc-400 transition hover:text-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#E9FF4E]"
                      >
                        {item}
                      </button>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2.5 sm:flex">
      <button
        type="button"
        class="rounded-lg border border-white/15 bg-white/5 px-4 py-2 font-medium text-sm text-zinc-100 shadow-sm transition hover:border-white/25 hover:bg-white/10 active:translate-y-px"
      >
        Read docs
      </button>
      <button
        type="button"
        class="inline-flex rounded-lg bg-[#E9FF4E] px-4 py-2 font-semibold text-[#131314] text-sm shadow-[0_8px_24px_rgba(233,255,78,0.22)] transition hover:bg-[#ddf447] active:translate-y-px"
      >
        Get started
      </button>
    </div>

    <details class="group relative lg:hidden">
      <summary class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-lg border border-white/15 bg-white/[0.055] text-zinc-100 transition hover:bg-white/[0.085]">
        <span class="sr-only">Open menu</span>
        <span aria-hidden="true" class="flex flex-col gap-1.5">
          <span class="block h-px w-4 bg-current"></span>
          <span class="block h-px w-4 bg-current"></span>
          <span class="block h-px w-4 bg-current"></span>
        </span>
      </summary>

      <div class="absolute right-0 top-12 w-[min(20rem,calc(100vw-2rem))] rounded-2xl border border-white/[0.1] bg-[#181819] p-3 shadow-[0_24px_80px_rgba(0,0,0,0.42)]">
        <div class="grid gap-2">
          {
            menuGroups.map((group) => (
              <section class="rounded-xl bg-white/[0.035] p-3">
                <p class="font-mono text-[#E9FF4E]/65 text-[0.64rem] uppercase tracking-[0.16em]">
                  {group.label}
                </p>
                {group.items.length > 0 && (
                  <div class="mt-2 grid gap-1">
                    {group.items.map((item) => (
                      <button type="button" class="text-left text-sm text-zinc-300">
                        {item}
                      </button>
                    ))}
                  </div>
                )}
              </section>
            ))
          }
        </div>
        <div class="mt-3 grid grid-cols-2 gap-2">
          <button
            type="button"
            class="rounded-lg border border-white/15 bg-white/5 px-3 py-2.5 font-medium text-sm text-zinc-100"
          >
            Read docs
          </button>
          <button
            type="button"
            class="rounded-lg bg-[#E9FF4E] px-3 py-2.5 font-semibold text-[#131314] text-sm"
          >
            Get started
          </button>
        </div>
      </div>
    </details>
  </div>
</header>
