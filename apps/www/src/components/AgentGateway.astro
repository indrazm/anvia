---
const capabilities = [
  {
    label: "Models",
    title: "Switch providers without rewiring",
    body: "Use the same agent contract across OpenAI, Anthropic, Gemini, Mistral, and local model adapters.",
  },
  {
    label: "Retrieval",
    title: "Bring your own memory layer",
    body: "Attach vector stores and embedding packages only when your agent needs grounded context.",
  },
  {
    label: "Operations",
    title: "Observe every run in production",
    body: "Connect tracing, sandboxed tools, and Studio workflows around the same runtime surface.",
  },
];

const gatewayNodes = [
  {
    name: "OpenAI",
    logo: "/assets/integrations/openai.svg",
    x: "19.2%",
    y: "26.4%",
    invert: true,
  },
  {
    name: "Anthropic",
    logo: "/assets/integrations/anthropic.svg",
    x: "19.2%",
    y: "48.2%",
    invert: true,
  },
  {
    name: "Gemini",
    logo: "/assets/integrations/gemini.svg",
    x: "19.2%",
    y: "70%",
  },
  {
    name: "React",
    logo: "/assets/integrations/react.svg",
    x: "81%",
    y: "26.4%",
  },
  {
    name: "Langfuse",
    logo: "/assets/integrations/langfuse.svg",
    x: "81%",
    y: "48.2%",
  },
  {
    name: "Chroma",
    logo: "/assets/integrations/chroma.svg",
    x: "81%",
    y: "70%",
  },
];
---

<section id="gateway" class="bg-[#131314] px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-2xl border border-white/[0.08] bg-[#121211] px-6 py-8 shadow-[0_24px_80px_rgba(0,0,0,0.22)] sm:px-8 lg:px-10 lg:py-10">
    <div class="grid items-center gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:gap-14">
      <div>
        <p class="font-mono text-[#E9FF4E]/70 text-[0.75rem] uppercase tracking-[0.18em]">
          Agent gateway
        </p>
        <h2 class="mt-4 max-w-2xl font-semibold text-4xl text-zinc-50 tracking-[-0.02em] sm:text-5xl">
          A cleaner path from model to product.
        </h2>
        <p class="mt-5 max-w-xl text-base text-zinc-400 leading-7 sm:text-lg">
          Compose model providers, retrieval, tools, traces, and app clients without turning your agent into integration glue.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <button
            type="button"
            class="inline-flex justify-center rounded-lg bg-[#E9FF4E] px-5 py-3 font-semibold text-[#131314] text-sm shadow-[0_14px_32px_rgba(233,255,78,0.18)] transition hover:bg-[#ddf447] active:translate-y-px"
          >
            Browse packages
          </button>
          <a
            href="/docs"
            class="inline-flex justify-center rounded-lg bg-white/[0.055] px-5 py-3 font-semibold text-sm text-zinc-100 transition hover:bg-white/[0.085] active:translate-y-px"
          >
            Read docs
          </a>
        </div>
      </div>

      <div class="relative -mx-4 sm:mx-0">
        <img
          src="/assets/illustrations/agent-gateway-minimal.png"
          alt="Minimal agent runtime diagram"
          width="1808"
          height="870"
          loading="lazy"
          decoding="async"
          class="relative w-full object-contain"
        />
        <div class="pointer-events-none absolute inset-0" aria-hidden="true">
          {
            gatewayNodes.map((node) => (
              <div
                class="gateway-logo-node"
                style={`--node-x: ${node.x}; --node-y: ${node.y};`}
              >
                <img
                  src={node.logo}
                  alt=""
                  class:list={["h-5 w-5 object-contain", node.invert && "brightness-0 invert"]}
                />
                <span>{node.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        capabilities.map((capability) => (
          <article>
            <p class="font-mono text-[#E9FF4E]/65 text-[0.68rem] uppercase tracking-[0.16em]">
              {capability.label}
            </p>
            <h3 class="mt-3 font-semibold text-xl text-zinc-100 tracking-[-0.01em]">
              {capability.title}
            </h3>
            <p class="mt-3 max-w-sm text-sm text-zinc-500 leading-6">
              {capability.body}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .gateway-logo-node {
    position: absolute;
    top: var(--node-y);
    left: var(--node-x);
    display: inline-flex;
    min-width: clamp(6.2rem, 9vw, 8.75rem);
    align-items: center;
    gap: 0.55rem;
    border-radius: 0.9rem;
    background: rgba(23, 23, 24, 0.92);
    padding: clamp(0.42rem, 0.8vw, 0.62rem) clamp(0.56rem, 1vw, 0.82rem);
    color: rgb(228 228 231);
    font-size: clamp(0.68rem, 1.15vw, 0.92rem);
    font-weight: 650;
    letter-spacing: -0.01em;
    transform: translate(-50%, -50%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 12px 36px rgba(0, 0, 0, 0.28);
  }

  @media (max-width: 520px) {
    .gateway-logo-node {
      min-width: 2.6rem;
      justify-content: center;
      padding: 0.5rem;
      border-radius: 0.8rem;
    }

    .gateway-logo-node span {
      display: none;
    }
  }
</style>
