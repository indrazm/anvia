---
import { getCollection } from "astro:content";
import DocsShell from "../../../components/docs/DocsShell.astro";
import { isPublishedDoc, sortDocs } from "../../../lib/docs";
import { packageLandingHref, packages } from "../../../lib/packages";

export async function getStaticPaths() {
  const docs = sortDocs((await getCollection("docs")).filter(isPublishedDoc));

  return packages.map((packageInfo) => ({
    params: { packageSlug: packageInfo.slug },
    props: { packageInfo, docs },
  }));
}

type PackageInfo = (typeof packages)[number];
type DocsEntry = Awaited<ReturnType<typeof getCollection<"docs">>>[number];

interface Props {
  packageInfo: PackageInfo;
  docs: DocsEntry[];
}

const { packageInfo, docs } = Astro.props;
const overviewHref = packageLandingHref(packageInfo.slug);
---

<DocsShell
  title={`${packageInfo.name} | Anvia Docs`}
  description={`Open the ${packageInfo.name} package overview.`}
  entries={docs}
  activeSection="basics"
  currentId="packages"
  customSidebarGroups={[
    {
      title: "Packages",
      entries: [{ id: "all-packages", href: "/docs/packages", label: "All packages" }],
    },
  ]}
  sidebarActiveId="all-packages"
  sidebarScrollKey={`anvia:docs-sidebar-scroll:packages:${packageInfo.slug}`}
>
  <section class="max-w-3xl" data-pagefind-body data-pagefind-meta="section:packages">
    <p class="font-mono text-[#2BF563]/70 text-[0.75rem] uppercase tracking-[0.18em]">
      Package
    </p>
    <h1 class="mt-4 font-semibold text-4xl text-zinc-50 leading-[1.02] tracking-[-0.02em] sm:text-5xl">
      {packageInfo.name}
    </h1>
    <p class="mt-4 text-lg text-zinc-300 leading-8">
      This package entry has moved to its Overview page.
    </p>
    <a
      href={overviewHref}
      class="mt-6 inline-flex font-semibold text-[#2BF563] text-sm transition hover:text-[#24dc59]"
    >
      Open Overview -&gt;
    </a>
  </section>
</DocsShell>

<script define:vars={{ overviewHref }}>
  window.location.replace(overviewHref);
</script>
